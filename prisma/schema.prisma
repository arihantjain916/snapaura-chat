generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Conversation {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  created_at  DateTime  @default(now())
  receiver_id String
  sender_id   String
  message     Message[]

  /// Order-independent "<idA>:<idB>" key for the pair, so the same two people
  /// cannot end up with two conversations. Optional because rows created
  /// before this field existed do not have it; run scripts/backfillPairKey.ts
  /// and then make this @unique.
  pair_key String?

  @@index([sender_id])
  @@index([receiver_id])
  @@index([pair_key])
}

model Group {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  message Message[]
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  created_at     DateTime @default(now())
  message        String
  sender_id      String
  receiver_id    String
  conversationId String?  @db.ObjectId
  groupId        String?  @db.ObjectId

  isReply Boolean?
  replyId String?  @db.ObjectId

  /// Read receipt. Set when the *receiver* opens the conversation, never by the
  /// sender. Defaults to false so rows written before this field existed read
  /// back as unread rather than as null.
  is_read Boolean   @default(false)
  read_at DateTime?

  conversation Conversation? @relation(fields: [conversationId], references: [id])
  group        Group?        @relation(fields: [groupId], references: [id])

  file_attachment Message_attachment[]

  @@index([conversationId])
  @@index([groupId])
  /// Messages are read newest-conversation-first and ordered by time; without
  /// this the sort was a collection scan.
  @@index([conversationId, created_at])
  /// Unread counts are per (conversation, recipient) and the conversation list
  /// asks for all of them at once.
  @@index([conversationId, receiver_id, is_read])
}

model Message_attachment {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  messageId String  @db.ObjectId
  fileUrl   String
  fileType  String
  fileName  String
  message   Message @relation(fields: [messageId], references: [id])

  @@index([messageId])
}
