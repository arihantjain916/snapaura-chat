# Port the service listens on. Must match the port published in
# docker-compose.yml (3001); the code previously defaulted to 5900 while the
# container published 3001, so nothing was reachable.
PORT=3001

# Comma-separated list of origins allowed to open a socket. Leave unset to
# allow any origin (development only).
SOCKET_ORIGINS=http://localhost:3000

# Base URL of the Laravel API, e.g. https://api.example.com/api
API_URL=

# Must match SECRET_KEY in the Laravel app: used for the server-to-server
# /user/info/{id} lookup.
SECRET_KEY=

# Must match JWT_SECRET in the Laravel app so tokens verify locally.
JWT_SECRET=

# MongoDB connection string for Prisma.
DATABASE_URL=

REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_HOST=
REDIS_PORT=6379

CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
